# LLM Provider (Ollama, OpenAI, Gemini, etc.)
GEMINI_API_KEY=
LLM_BASE_URL=http://localhost:11434/v1
LLM_MODEL=llama3.2

# Embeddings (Ollama, OpenAI, Gemini)
EMBEDDING_BASE_URL=http://localhost:11434/v1
EMBEDDING_MODEL=llama3.2

# Reranking (optional, falls back to cosine similarity)
COHERE_API_KEY=

# Vector DB (use :memory: for local dev)
QDRANT_URL=:memory:
QDRANT_API_KEY=

# API Security
API_KEY=changeme_in_prod

# Pipeline Config
TOP_K_RETRIEVE=20
TOP_K_RERANK=5
CHUNK_SIZE=512
CHUNK_OVERLAP=50
